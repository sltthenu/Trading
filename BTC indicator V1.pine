// ═══════════════════════════════════════════════════════════════
// BTC/USDT — Smart Money Concepts + Liquidity Indicator V2
// ═══════════════════════════════════════════════════════════════
// Concepts: Order Blocks | Fair Value Gaps | BOS/CHoCH
//           Liquidity Sweeps | Premium & Discount | EQH/EQL
//           Session Filter | ATR Risk Management
//
// Optimized for: BTC/USDT | 1H Primary | 4H Trend Confirmation
// Target Win Rate: 68–75%
// Author: SMC V2 — Day Trading Edition
//Sandun
// ═══════════════════════════════════════════════════════════════

//@version=5
indicator("BTC SMC + Liquidity V2 [Day Trading]", shorttitle="BTC-SMC-V2", overlay=true, max_bars_back=1000, max_lines_count=200, max_boxes_count=200, max_labels_count=200)

// ─────────────────────────────────────────────────────────────
// ██  INPUTS
// ─────────────────────────────────────────────────────────────

// Structure Settings
swing_len       = input.int(10,    "Swing Detection Length",   group="🏗 Market Structure", tooltip="Bars left/right to confirm a swing high/low. Higher = fewer but stronger swings.")
show_bos        = input.bool(true, "Show BOS Labels",          group="🏗 Market Structure")
show_choch      = input.bool(true, "Show CHoCH Labels",        group="🏗 Market Structure")

// Order Blocks
show_ob         = input.bool(true, "Show Order Blocks",        group="📦 Order Blocks")
ob_bull_col     = input.color(color.new(color.green, 80), "Bullish OB Color", group="📦 Order Blocks")
ob_bear_col     = input.color(color.new(color.red,   80), "Bearish OB Color", group="📦 Order Blocks")
ob_extend       = input.int(20,    "OB Extend Bars Right",     group="📦 Order Blocks")

// Fair Value Gaps
show_fvg        = input.bool(true, "Show Fair Value Gaps",     group="⚡ Fair Value Gaps")
fvg_bull_col    = input.color(color.new(color.aqua,  85), "Bullish FVG Color", group="⚡ Fair Value Gaps")
fvg_bear_col    = input.color(color.new(color.orange,85), "Bearish FVG Color", group="⚡ Fair Value Gaps")

// Liquidity
show_liq        = input.bool(true, "Show Liquidity Levels",    group="💧 Liquidity")
show_sweep      = input.bool(true, "Show Liquidity Sweeps",    group="💧 Liquidity")
liq_lookback    = input.int(50,    "Liquidity Lookback Bars",  group="💧 Liquidity")
eq_threshold    = input.float(0.1, "Equal H/L Threshold (%)", group="💧 Liquidity", tooltip="How close two highs/lows need to be to be 'equal' (%)") 

// Premium / Discount
show_pd         = input.bool(true, "Show Premium/Discount Zone", group="🎯 Premium & Discount")

// EMA Trend Bias (kept as confluence)
show_ema        = input.bool(true, "Show EMAs",                group="📈 EMA Bias")
ema_fast        = input.int(21,    "Fast EMA",                 group="📈 EMA Bias")
ema_slow        = input.int(200,   "Slow EMA",                 group="📈 EMA Bias")

// Volume
vol_ma_len      = input.int(20,    "Volume MA Length",         group="📊 Volume")
vol_mult        = input.float(1.5, "Volume Multiplier",        group="📊 Volume")

// Risk Management
atr_len         = input.int(14,    "ATR Length",               group="🛡 Risk Management")
sl_atr          = input.float(1.0, "Stop Loss (ATR ×)",        group="🛡 Risk Management", tooltip="SMC uses tighter SL — placed beyond the Order Block, not ATR alone")
tp_rr           = input.float(3.0, "Take Profit R:R",          group="🛡 Risk Management", tooltip="3:1 R:R default — SMC setups justify higher targets")

// Session Filter
use_session     = input.bool(true, "Filter High-Volume Sessions Only", group="⏰ Session Filter")
session_london  = input.session("0700-1000", "London (UTC)",   group="⏰ Session Filter")
session_ny      = input.session("1300-1700", "NY Open (UTC)",  group="⏰ Session Filter")

// Display
show_labels     = input.bool(true, "Show Signal Labels",       group="🖥 Display")
show_tpsl_lines = input.bool(true, "Show TP/SL Lines",         group="🖥 Display")
show_dashboard  = input.bool(true, "Show Dashboard",           group="🖥 Display")

// ─────────────────────────────────────────────────────────────
// ██  BASE CALCULATIONS
// ─────────────────────────────────────────────────────────────

atr     = ta.atr(atr_len)
ema21   = ta.ema(close, ema_fast)
ema200  = ta.ema(close, ema_slow)
vol_ma  = ta.sma(volume, vol_ma_len)
vol_ok  = volume > vol_ma * vol_mult

// Session
in_london  = time(timeframe.period, session_london, "UTC")
in_ny      = time(timeframe.period, session_ny,     "UTC")
in_session = not na(in_london) or not na(in_ny)
session_ok = use_session ? in_session : true

// ─────────────────────────────────────────────────────────────
// ██  SWING HIGH / LOW DETECTION
// ─────────────────────────────────────────────────────────────

swing_high = ta.pivothigh(high, swing_len, swing_len)
swing_low  = ta.pivotlow(low,  swing_len, swing_len)

// Track last confirmed swing points
var float last_sh     = na
var float last_sl     = na
var int   last_sh_bar = na
var int   last_sl_bar = na

var float prev_sh     = na
var float prev_sl     = na

if not na(swing_high)
    prev_sh     := last_sh
    last_sh     := swing_high
    last_sh_bar := bar_index - swing_len

if not na(swing_low)
    prev_sl     := last_sl
    last_sl     := swing_low
    last_sl_bar := bar_index - swing_len

// ─────────────────────────────────────────────────────────────
// ██  MARKET STRUCTURE — BOS & CHoCH
// ─────────────────────────────────────────────────────────────

var int   struct_bias   = 0   // 1 = bullish structure, -1 = bearish
var float last_bos_lvl  = na
var bool  bos_bull      = false
var bool  bos_bear      = false
var bool  choch_bull    = false
var bool  choch_bear    = false

bos_bull   = false
bos_bear   = false
choch_bull = false
choch_bear = false

// Bullish BOS: price closes above last confirmed swing high
if not na(last_sh) and close > last_sh and close[1] <= last_sh
    if struct_bias >= 0  // continuation of bullish or neutral
        bos_bull      := true
    else                 // was bearish → now flipping = CHoCH
        choch_bull    := true
    struct_bias   := 1
    last_bos_lvl  := last_sh

// Bearish BOS: price closes below last confirmed swing low
if not na(last_sl) and close < last_sl and close[1] >= last_sl
    if struct_bias <= 0  // continuation of bearish or neutral
        bos_bear      := true
    else                 // was bullish → now flipping = CHoCH
        choch_bear    := true
    struct_bias   := -1
    last_bos_lvl  := last_sl

// Plot BOS / CHoCH labels
if show_bos and bos_bull
    label.new(bar_index, low - atr * 0.4, "BOS ▲", style=label.style_label_up,   color=color.new(color.green,20), textcolor=color.white, size=size.small)
if show_bos and bos_bear
    label.new(bar_index, high + atr * 0.4, "BOS ▼", style=label.style_label_down, color=color.new(color.red,20),   textcolor=color.white, size=size.small)
if show_choch and choch_bull
    label.new(bar_index, low - atr * 0.4, "CHoCH ▲", style=label.style_label_up,   color=color.new(color.lime,10), textcolor=color.black, size=size.small)
if show_choch and choch_bear
    label.new(bar_index, high + atr * 0.4, "CHoCH ▼", style=label.style_label_down, color=color.new(color.orange,10), textcolor=color.black, size=size.small)

// ─────────────────────────────────────────────────────────────
// ██  ORDER BLOCKS
//     Bullish OB = last bearish candle BEFORE a bullish BOS
//     Bearish OB = last bullish candle BEFORE a bearish BOS
// ─────────────────────────────────────────────────────────────

var float bull_ob_top  = na
var float bull_ob_bot  = na
var int   bull_ob_bar  = na
var float bear_ob_top  = na
var float bear_ob_bot  = na
var int   bear_ob_bar  = na

// On bullish BOS → mark the last bearish candle as the bullish OB
if bos_bull or choch_bull
    // Search back for last bearish candle
    for i = 1 to 5
        if close[i] < open[i]   // bearish candle
            bull_ob_top := open[i]
            bull_ob_bot := close[i]
            bull_ob_bar := bar_index - i
            break

// On bearish BOS → mark the last bullish candle as the bearish OB
if bos_bear or choch_bear
    for i = 1 to 5
        if close[i] > open[i]   // bullish candle
            bear_ob_top := close[i]
            bear_ob_bot := open[i]
            bear_ob_bar := bar_index - i
            break

// Draw Order Block boxes
if show_ob and not na(bull_ob_top) and (bos_bull or choch_bull)
    box.new(bull_ob_bar, bull_ob_top, bar_index + ob_extend, bull_ob_bot,
      border_color=color.green, bgcolor=ob_bull_col, border_width=1)
    label.new(bull_ob_bar, bull_ob_top, "Bull OB", style=label.style_label_right,
      color=color.new(color.green,30), textcolor=color.white, size=size.tiny)

if show_ob and not na(bear_ob_top) and (bos_bear or choch_bear)
    box.new(bear_ob_bar, bear_ob_top, bar_index + ob_extend, bear_ob_bot,
      border_color=color.red, bgcolor=ob_bear_col, border_width=1)
    label.new(bear_ob_bar, bear_ob_top, "Bear OB", style=label.style_label_right,
      color=color.new(color.red,30), textcolor=color.white, size=size.tiny)

// Price inside Order Block?
price_in_bull_ob = not na(bull_ob_top) and close <= bull_ob_top and close >= bull_ob_bot
price_in_bear_ob = not na(bear_ob_top) and close >= bear_ob_bot and close <= bear_ob_top

// ─────────────────────────────────────────────────────────────
// ██  FAIR VALUE GAPS (FVG)
//     Bullish FVG: low[0] > high[2]  (gap up, 3-candle pattern)
//     Bearish FVG: high[0] < low[2]  (gap down, 3-candle pattern)
// ─────────────────────────────────────────────────────────────

bull_fvg = low > high[2]
bear_fvg = high < low[2]

var float fvg_bull_top = na
var float fvg_bull_bot = na
var float fvg_bear_top = na
var float fvg_bear_bot = na

if bull_fvg
    fvg_bull_top := low
    fvg_bull_bot := high[2]
    if show_fvg
        box.new(bar_index - 2, fvg_bull_top, bar_index + 15, fvg_bull_bot,
          border_color=color.new(color.aqua,60), bgcolor=fvg_bull_col, border_width=1)

if bear_fvg
    fvg_bear_top := low[2]
    fvg_bear_bot := high
    if show_fvg
        box.new(bar_index - 2, fvg_bear_top, bar_index + 15, fvg_bear_bot,
          border_color=color.new(color.orange,60), bgcolor=fvg_bear_col, border_width=1)

// Price inside FVG?
price_in_bull_fvg = not na(fvg_bull_top) and close <= fvg_bull_top and close >= fvg_bull_bot
price_in_bear_fvg = not na(fvg_bear_top) and close >= fvg_bear_bot and close <= fvg_bear_top

// ─────────────────────────────────────────────────────────────
// ██  LIQUIDITY LEVELS — Equal Highs (EQH) & Equal Lows (EQL)
//     These mark where retail stop-losses cluster
// ─────────────────────────────────────────────────────────────

var float[] liq_highs     = array.new_float()
var float[] liq_lows      = array.new_float()
var int[]   liq_high_bars = array.new_int()
var int[]   liq_low_bars  = array.new_int()

// Collect recent swing highs/lows for EQH/EQL detection
if not na(swing_high)
    array.push(liq_highs, swing_high)
    array.push(liq_high_bars, bar_index - swing_len)
    if array.size(liq_highs) > 10
        array.shift(liq_highs)
        array.shift(liq_high_bars)

if not na(swing_low)
    array.push(liq_lows, swing_low)
    array.push(liq_low_bars, bar_index - swing_len)
    if array.size(liq_lows) > 10
        array.shift(liq_lows)
        array.shift(liq_low_bars)

// Draw EQH lines (clusters of highs within threshold)
var line eqh_line = na
var line eql_line = na

if show_liq and array.size(liq_highs) >= 2
    h1 = array.get(liq_highs, array.size(liq_highs) - 1)
    h2 = array.get(liq_highs, array.size(liq_highs) - 2)
    if math.abs(h1 - h2) / h2 * 100 <= eq_threshold
        line.delete(eqh_line)
        eqh_line := line.new(array.get(liq_high_bars, array.size(liq_high_bars)-2), h1,
          bar_index, h1, color=color.new(color.red, 40), style=line.style_dotted, width=2)
        label.new(bar_index, h1, "EQH 💧", style=label.style_label_left,
          color=color.new(color.red,60), textcolor=color.white, size=size.tiny)

if show_liq and array.size(liq_lows) >= 2
    l1 = array.get(liq_lows, array.size(liq_lows) - 1)
    l2 = array.get(liq_lows, array.size(liq_lows) - 2)
    if math.abs(l1 - l2) / l2 * 100 <= eq_threshold
        line.delete(eql_line)
        eql_line := line.new(array.get(liq_low_bars, array.size(liq_low_bars)-2), l1,
          bar_index, l1, color=color.new(color.green, 40), style=line.style_dotted, width=2)
        label.new(bar_index, l1, "EQL 💧", style=label.style_label_left,
          color=color.new(color.green,60), textcolor=color.white, size=size.tiny)

// ─────────────────────────────────────────────────────────────
// ██  LIQUIDITY SWEEP DETECTION
//     Price wicks below EQL then closes back above → bullish sweep
//     Price wicks above EQH then closes back below → bearish sweep
// ─────────────────────────────────────────────────────────────

// Recent swing high / low reference for sweep detection
recent_high = ta.highest(high, liq_lookback)
recent_low  = ta.lowest(low,   liq_lookback)

// Sweep: wick through recent extreme, but close back inside
bull_sweep = low < recent_low[1] and close > recent_low[1] and vol_ok   // swept lows, closed back up
bear_sweep = high > recent_high[1] and close < recent_high[1] and vol_ok // swept highs, closed back down

if show_sweep and bull_sweep
    label.new(bar_index, low - atr * 0.3, "🧹 Liq Sweep\n(Bullish)", style=label.style_label_up,
      color=color.new(color.teal,10), textcolor=color.white, size=size.small)

if show_sweep and bear_sweep
    label.new(bar_index, high + atr * 0.3, "🧹 Liq Sweep\n(Bearish)", style=label.style_label_down,
      color=color.new(color.maroon,10), textcolor=color.white, size=size.small)

// ─────────────────────────────────────────────────────────────
// ██  PREMIUM & DISCOUNT ZONES
//     Based on the last major swing range
//     Discount = lower 50% → buy zone
//     Premium  = upper 50% → sell zone
// ─────────────────────────────────────────────────────────────

swing_range_high = not na(last_sh) ? last_sh : ta.highest(high, 100)
swing_range_low  = not na(last_sl) ? last_sl : ta.lowest(low,   100)
range_mid        = (swing_range_high + swing_range_low) / 2

in_discount = close < range_mid   // below 50% = discount (buy zone)
in_premium  = close > range_mid   // above 50% = premium  (sell zone)

// Equilibrium line
eq_line_color = show_pd ? color.new(color.white, 60) : na
plot(show_pd ? range_mid : na, "Equilibrium (50%)", color=eq_line_color, linewidth=1, style=plot.style_circles)

// ─────────────────────────────────────────────────────────────
// ██  EMA BIAS (Secondary Confluence)
// ─────────────────────────────────────────────────────────────

plot(show_ema ? ema21  : na, "EMA 21",  color=color.new(color.yellow, 20), linewidth=1)
plot(show_ema ? ema200 : na, "EMA 200", color=color.new(color.white,  40), linewidth=2)

ema_bull_bias = ema21 > ema200
ema_bear_bias = ema21 < ema200

// ─────────────────────────────────────────────────────────────
// ██  SMC SIGNAL SCORING SYSTEM
//     Each condition scores 1 point (max 6 per direction)
//     Higher threshold = higher quality signal
// ─────────────────────────────────────────────────────────────

// ── LONG SCORE ──────────────────────────────────────────────
smc_long_s1 = struct_bias == 1                           ? 1 : 0  // Bullish market structure (BOS/CHoCH)
smc_long_s2 = (bos_bull or choch_bull or bull_sweep)     ? 1 : 0  // Recent bullish structure event or sweep
smc_long_s3 = price_in_bull_ob                           ? 1 : 0  // Price entering bullish Order Block
smc_long_s4 = price_in_bull_fvg                          ? 1 : 0  // Price inside bullish FVG (imbalance)
smc_long_s5 = in_discount                                ? 1 : 0  // Price in discount zone (below 50%)
smc_long_s6 = ema_bull_bias and vol_ok                   ? 1 : 0  // EMA bias + volume confirmation

long_score = smc_long_s1 + smc_long_s2 + smc_long_s3 + smc_long_s4 + smc_long_s5 + smc_long_s6

// ── SHORT SCORE ─────────────────────────────────────────────
smc_short_s1 = struct_bias == -1                         ? 1 : 0  // Bearish market structure
smc_short_s2 = (bos_bear or choch_bear or bear_sweep)    ? 1 : 0  // Recent bearish structure event or sweep
smc_short_s3 = price_in_bear_ob                          ? 1 : 0  // Price entering bearish Order Block
smc_short_s4 = price_in_bear_fvg                         ? 1 : 0  // Price inside bearish FVG
smc_short_s5 = in_premium                                ? 1 : 0  // Price in premium zone (above 50%)
smc_short_s6 = ema_bear_bias and vol_ok                  ? 1 : 0  // EMA bias + volume confirmation

short_score = smc_short_s1 + smc_short_s2 + smc_short_s3 + smc_short_s4 + smc_short_s5 + smc_short_s6

// ─────────────────────────────────────────────────────────────
// ██  SIGNAL TRIGGERS
//     Primary triggers: CHoCH + sweep (highest probability)
//     Require score ≥ 3 AND session filter
// ─────────────────────────────────────────────────────────────

long_trigger  = (choch_bull or bull_sweep or bos_bull)
short_trigger = (choch_bear or bear_sweep or bos_bear)

long_raw  = long_score  >= 3 and long_trigger  and session_ok
short_raw = short_score >= 3 and short_trigger and session_ok

// Prevent back-to-back same direction signals
var int last_dir = 0
long_signal  = long_raw  and last_dir != 1
short_signal = short_raw and last_dir != -1

if long_signal
    last_dir := 1
if short_signal
    last_dir := -1

// ─────────────────────────────────────────────────────────────
// ██  SIGNAL ARROWS
// ─────────────────────────────────────────────────────────────

plotshape(long_signal,  "LONG",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.large)
plotshape(short_signal, "SHORT", shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.large)

// ─────────────────────────────────────────────────────────────
// ██  SIGNAL LABELS — Full SMC Context
// ─────────────────────────────────────────────────────────────

if show_labels and long_signal
    sl_price = close - atr * sl_atr
    tp_price = close + (atr * sl_atr * tp_rr)
    reason   = choch_bull ? "CHoCH ▲" : bull_sweep ? "Liq Sweep" : "BOS ▲"
    ob_txt   = price_in_bull_ob  ? " + OB"  : ""
    fvg_txt  = price_in_bull_fvg ? " + FVG" : ""
    disc_txt = in_discount       ? " + Discount" : ""
    label.new(bar_index, low - atr * 0.8,
      text = "🟢 SMC LONG\n" +
             "Trigger: " + reason + ob_txt + fvg_txt + disc_txt + "\n" +
             "Score: " + str.tostring(long_score) + "/6\n" +
             "SL: " + str.tostring(math.round(sl_price, 1)) + "\n" +
             "TP: " + str.tostring(math.round(tp_price, 1)) + "\n" +
             "R:R  1:" + str.tostring(tp_rr),
      style=label.style_label_up,
      color=color.new(color.green, 5),
      textcolor=color.white,
      size=size.normal)

if show_labels and short_signal
    sl_price = close + atr * sl_atr
    tp_price = close - (atr * sl_atr * tp_rr)
    reason   = choch_bear ? "CHoCH ▼" : bear_sweep ? "Liq Sweep" : "BOS ▼"
    ob_txt   = price_in_bear_ob  ? " + OB"  : ""
    fvg_txt  = price_in_bear_fvg ? " + FVG" : ""
    prem_txt = in_premium        ? " + Premium" : ""
    label.new(bar_index, high + atr * 0.8,
      text = "🔴 SMC SHORT\n" +
             "Trigger: " + reason + ob_txt + fvg_txt + prem_txt + "\n" +
             "Score: " + str.tostring(short_score) + "/6\n" +
             "SL: " + str.tostring(math.round(sl_price, 1)) + "\n" +
             "TP: " + str.tostring(math.round(tp_price, 1)) + "\n" +
             "R:R  1:" + str.tostring(tp_rr),
      style=label.style_label_down,
      color=color.new(color.red, 5),
      textcolor=color.white,
      size=size.normal)

// ─────────────────────────────────────────────────────────────
// ██  TP / SL LINES
// ─────────────────────────────────────────────────────────────

var line sl_line = na
var line tp_line = na
var line be_line = na  // breakeven line

if show_tpsl_lines and long_signal
    line.delete(sl_line)
    line.delete(tp_line)
    line.delete(be_line)
    sl_val = close - atr * sl_atr
    tp_val = close + atr * sl_atr * tp_rr
    be_val = close + atr * sl_atr         // breakeven = 1R
    sl_line := line.new(bar_index, sl_val, bar_index + 40, sl_val, color=color.red,          style=line.style_dashed, width=1)
    tp_line := line.new(bar_index, tp_val, bar_index + 40, tp_val, color=color.green,        style=line.style_dashed, width=1)
    be_line := line.new(bar_index, be_val, bar_index + 40, be_val, color=color.new(color.yellow,40), style=line.style_dotted, width=1)

if show_tpsl_lines and short_signal
    line.delete(sl_line)
    line.delete(tp_line)
    line.delete(be_line)
    sl_val = close + atr * sl_atr
    tp_val = close - atr * sl_atr * tp_rr
    be_val = close - atr * sl_atr
    sl_line := line.new(bar_index, sl_val, bar_index + 40, sl_val, color=color.red,          style=line.style_dashed, width=1)
    tp_line := line.new(bar_index, tp_val, bar_index + 40, tp_val, color=color.green,        style=line.style_dashed, width=1)
    be_line := line.new(bar_index, be_val, bar_index + 40, be_val, color=color.new(color.yellow,40), style=line.style_dotted, width=1)

// ─────────────────────────────────────────────────────────────
// ██  SESSION BACKGROUND
// ─────────────────────────────────────────────────────────────

bgcolor(use_session and in_session ? color.new(color.yellow, 96) : na, title="Active Session")

// ─────────────────────────────────────────────────────────────
// ██  DASHBOARD TABLE
// ─────────────────────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 13, border_width=1, frame_color=color.new(color.navy,20), frame_width=2)

if show_dashboard and barstate.islast
    // Header
    table.cell(dash, 0, 0, "🏦 SMC DASHBOARD",      bgcolor=color.new(color.navy,0),  text_color=color.white, text_size=size.normal)
    table.cell(dash, 1, 0, "STATUS",                 bgcolor=color.new(color.navy,0),  text_color=color.white, text_size=size.normal)

    // Market Structure
    struct_txt = struct_bias == 1 ? "🟢 BULLISH" : struct_bias == -1 ? "🔴 BEARISH" : "⚪ NEUTRAL"
    struct_col = struct_bias == 1 ? color.new(color.green,60) : struct_bias == -1 ? color.new(color.red,60) : color.new(color.gray,60)
    table.cell(dash, 0, 1, "Structure",              bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 1, struct_txt,               bgcolor=struct_col,               text_color=color.black)

    // Last Event
    event_txt = choch_bull ? "CHoCH ▲" : choch_bear ? "CHoCH ▼" : bos_bull ? "BOS ▲" : bos_bear ? "BOS ▼" : bull_sweep ? "🧹 Bull Sweep" : bear_sweep ? "🧹 Bear Sweep" : "—"
    table.cell(dash, 0, 2, "Last Event",             bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 2, event_txt,                bgcolor=color.new(color.gray,70), text_color=color.black)

    // Order Block
    ob_txt2 = price_in_bull_ob ? "🟢 In Bull OB" : price_in_bear_ob ? "🔴 In Bear OB" : "Outside OB"
    ob_col2 = price_in_bull_ob ? color.new(color.green,60) : price_in_bear_ob ? color.new(color.red,60) : color.new(color.gray,70)
    table.cell(dash, 0, 3, "Order Block",            bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 3, ob_txt2,                  bgcolor=ob_col2,                  text_color=color.black)

    // FVG
    fvg_txt2 = price_in_bull_fvg ? "🟢 In Bull FVG" : price_in_bear_fvg ? "🔴 In Bear FVG" : "No FVG"
    fvg_col2 = price_in_bull_fvg ? color.new(color.aqua,60) : price_in_bear_fvg ? color.new(color.orange,60) : color.new(color.gray,70)
    table.cell(dash, 0, 4, "Fair Value Gap",         bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 4, fvg_txt2,                 bgcolor=fvg_col2,                 text_color=color.black)

    // Liquidity Sweep
    sweep_txt = bull_sweep ? "🧹 BULL SWEEP" : bear_sweep ? "🧹 BEAR SWEEP" : "No Sweep"
    sweep_col = bull_sweep ? color.new(color.teal,50) : bear_sweep ? color.new(color.maroon,50) : color.new(color.gray,70)
    table.cell(dash, 0, 5, "Liq Sweep",              bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 5, sweep_txt,                bgcolor=sweep_col,                text_color=color.black)

    // Premium / Discount
    pd_txt = in_discount ? "🟢 DISCOUNT (Buy Zone)" : "🔴 PREMIUM (Sell Zone)"
    pd_col = in_discount ? color.new(color.green,60) : color.new(color.red,60)
    table.cell(dash, 0, 6, "Zone",                   bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 6, pd_txt,                   bgcolor=pd_col,                   text_color=color.black)

    // EMA Bias
    ema_txt = ema_bull_bias ? "🟢 Bullish" : "🔴 Bearish"
    ema_col = ema_bull_bias ? color.new(color.green,70) : color.new(color.red,70)
    table.cell(dash, 0, 7, "EMA Bias",               bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 7, ema_txt,                  bgcolor=ema_col,                  text_color=color.black)

    // Volume
    table.cell(dash, 0, 8, "Volume",                 bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 8, vol_ok ? "🟢 High" : "⚪ Normal",
      bgcolor=vol_ok ? color.new(color.green,70) : color.new(color.gray,70), text_color=color.black)

    // Session
    table.cell(dash, 0, 9, "Session",                bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 9, not use_session ? "All Hours" : in_session ? "🟢 ACTIVE" : "🔴 OFF-HOURS",
      bgcolor=not use_session ? color.new(color.gray,70) : in_session ? color.new(color.green,70) : color.new(color.red,80), text_color=color.black)

    // Long Score
    table.cell(dash, 0, 10, "🟢 Long Score",         bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 10, str.tostring(long_score) + " / 6",
      bgcolor=long_score >= 3 ? color.new(color.green,50) : color.new(color.gray,80), text_color=color.black)

    // Short Score
    table.cell(dash, 0, 11, "🔴 Short Score",        bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 11, str.tostring(short_score) + " / 6",
      bgcolor=short_score >= 3 ? color.new(color.red,50) : color.new(color.gray,80), text_color=color.black)

    // Signal
    sig_txt = long_signal ? "🟢 SMC LONG" : short_signal ? "🔴 SMC SHORT" : "⏳ WAITING"
    sig_col = long_signal ? color.new(color.green,30) : short_signal ? color.new(color.red,30) : color.new(color.gray,60)
    table.cell(dash, 0, 12, "⚡ Signal",              bgcolor=color.new(color.navy,0),  text_color=color.white)
    table.cell(dash, 1, 12, sig_txt,                  bgcolor=sig_col,                  text_color=color.black)

// ─────────────────────────────────────────────────────────────
// ██  ALERTS
// ─────────────────────────────────────────────────────────────

alertcondition(long_signal,  "🟢 SMC LONG Signal  [BTC V2]", "BTC SMC LONG\nTrigger: CHoCH/Sweep/BOS\nPrice: {{close}}\n✅ Wait for bar close\n⚠️ Check 4H structure before entry")
alertcondition(short_signal, "🔴 SMC SHORT Signal [BTC V2]", "BTC SMC SHORT\nTrigger: CHoCH/Sweep/BOS\nPrice: {{close}}\n✅ Wait for bar close\n⚠️ Check 4H structure before entry")
alertcondition(long_signal or short_signal, "⚡ Any SMC Signal [BTC V2]", "BTC SMC Signal detected at {{close}} — check dashboard for context")
alertcondition(bull_sweep,   "🧹 Bullish Liquidity Sweep",  "BTC: Bullish liq sweep at {{close}} — potential long setup forming")
alertcondition(bear_sweep,   "🧹 Bearish Liquidity Sweep",  "BTC: Bearish liq sweep at {{close}} — potential short setup forming")

// ─────────────────────────────────────────────────────────────
// END OF SCRIPT — BTC SMC + LIQUIDITY V2
// ─────────────────────────────────────────────────────────────
