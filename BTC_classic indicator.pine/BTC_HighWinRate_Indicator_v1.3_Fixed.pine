// ============================================================
// BTC/USDT Day Trading Optimized Indicator (60%+ Win Rate)
// Combines: EMA Trend + RSI + MACD + Bollinger Bands + Volume
// Optimized for: DAY TRADING | Primary: 1H | Confirm: 4H
// Best Hours: NY Open 13:00–17:00 UTC | London 07:00–10:00 UTC
// v1.3 — FIXED: floating label, TP/SL line detachment
// ============================================================

//@version=5
indicator(title="BTC Day Trading Signals [1H Optimized]", shorttitle="BTC-DT1H", overlay=true, max_bars_back=500)

// ─────────────────────────────────────────────
// ██  INPUTS
// ─────────────────────────────────────────────

ema_fast      = input.int(21,    "Fast EMA",                  group="📈 Trend Filter (EMA)")
ema_mid       = input.int(50,    "Mid EMA",                   group="📈 Trend Filter (EMA)")
ema_slow      = input.int(200,   "Slow EMA",                  group="📈 Trend Filter (EMA)")

rsi_len       = input.int(14,    "RSI Length",                group="📊 RSI Settings")
rsi_ob        = input.int(70,    "Overbought",                group="📊 RSI Settings")
rsi_os        = input.int(30,    "Oversold",                  group="📊 RSI Settings")

macd_fast     = input.int(12,    "MACD Fast",                 group="⚡ MACD Settings")
macd_slow     = input.int(26,    "MACD Slow",                 group="⚡ MACD Settings")
macd_sig      = input.int(9,     "MACD Signal",               group="⚡ MACD Settings")

bb_len        = input.int(20,    "BB Length",                 group="🎯 Bollinger Bands")
bb_mult       = input.float(2.0, "BB Multiplier",             group="🎯 Bollinger Bands")

vol_ma_len    = input.int(20,    "Volume MA Length",          group="📦 Volume Filter")
vol_mult      = input.float(1.5, "Min Volume Mult",           group="📦 Volume Filter")

min_signals   = input.int(3,     "Min Confirmations (2–4)",  group="✅ Signal Quality", minval=2, maxval=4)

show_labels   = input.bool(true,  "Show Signal Labels",       group="🖥 Display")
show_bg       = input.bool(true,  "Show Trend Background",    group="🖥 Display")
show_tp_sl    = input.bool(true,  "Show TP / SL Lines",       group="🖥 Display")
show_htf_hint = input.bool(true,  "Show 4H Trend Reminder",  group="🖥 Display")
show_dash     = input.bool(true,  "Show Dashboard",           group="🖥 Display")

atr_len       = input.int(14,    "ATR Length",                group="🛡 Risk Management")
sl_atr_mult   = input.float(1.2, "Stop Loss (ATR ×)",         group="🛡 Risk Management")
tp_atr_mult   = input.float(2.5, "Take Profit (ATR ×)",       group="🛡 Risk Management")

use_session   = input.bool(true,           "Filter High-Volume Sessions", group="⏰ Session Filter (UTC)")
session_1     = input.session("0700-1000", "London Open (UTC)",           group="⏰ Session Filter (UTC)")
session_2     = input.session("1300-1700", "NY Open / Overlap (UTC)",     group="⏰ Session Filter (UTC)")

// ─────────────────────────────────────────────
// ██  CALCULATIONS
// ─────────────────────────────────────────────

ema21   = ta.ema(close, ema_fast)
ema50   = ta.ema(close, ema_mid)
ema200  = ta.ema(close, ema_slow)
rsi     = ta.rsi(close, rsi_len)

[macdLine, signalLine, histLine] = ta.macd(close, macd_fast, macd_slow, macd_sig)
macd_bull       = macdLine > signalLine
macd_bear       = macdLine < signalLine
macd_cross_up   = ta.crossover(macdLine,  signalLine)
macd_cross_down = ta.crossunder(macdLine, signalLine)

bb_basis = ta.sma(close, bb_len)
bb_dev   = bb_mult * ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_width = (bb_upper - bb_lower) / bb_basis

vol_ma   = ta.sma(volume, vol_ma_len)
vol_ok   = volume > vol_ma * vol_mult
atr      = ta.atr(atr_len)

// ─────────────────────────────────────────────
// ██  SESSION FILTER
// ─────────────────────────────────────────────

in_london  = time(timeframe.period, session_1, "UTC")
in_ny      = time(timeframe.period, session_2, "UTC")
in_session = not na(in_london) or not na(in_ny)
session_ok = use_session ? in_session : true

// ─────────────────────────────────────────────
// ██  TREND & CONDITIONS
// ─────────────────────────────────────────────

uptrend   = ema21 > ema50 and ema50 > ema200
downtrend = ema21 < ema50 and ema50 < ema200

price_above = close > ema21 and close > ema50
price_below = close < ema21 and close < ema50

rsi_bull_zone  = rsi > 50 and rsi < rsi_ob
rsi_bear_zone  = rsi < 50 and rsi > rsi_os
rsi_coming_up  = ta.crossover(rsi, 50)
rsi_coming_dn  = ta.crossunder(rsi, 50)
rsi_bounce     = rsi < 45 and rsi > rsi_os

bb_bounce_low  = low  <= bb_lower and close > bb_lower
bb_bounce_high = high >= bb_upper and close < bb_upper
bb_breakout_up = close > bb_upper and close[1] <= bb_upper[1]
bb_breakout_dn = close < bb_lower and close[1] >= bb_lower[1]

// ─────────────────────────────────────────────
// ██  SCORING
// ─────────────────────────────────────────────

long_c1    = uptrend                                       ? 1 : 0
long_c2    = price_above                                   ? 1 : 0
long_c3    = (rsi_bull_zone or rsi_bounce)                 ? 1 : 0
long_c4    = macd_bull                                     ? 1 : 0
long_c5    = (bb_bounce_low or bb_breakout_up) and vol_ok  ? 1 : 0
long_score = long_c1 + long_c2 + long_c3 + long_c4 + long_c5

short_c1    = downtrend                                      ? 1 : 0
short_c2    = price_below                                    ? 1 : 0
short_c3    = rsi_bear_zone                                  ? 1 : 0
short_c4    = macd_bear                                      ? 1 : 0
short_c5    = (bb_bounce_high or bb_breakout_dn) and vol_ok  ? 1 : 0
short_score = short_c1 + short_c2 + short_c3 + short_c4 + short_c5

// ─────────────────────────────────────────────
// ██  SIGNALS
// ─────────────────────────────────────────────

long_signal  = long_score  >= min_signals and (macd_cross_up   or rsi_coming_up or bb_bounce_low)  and session_ok
short_signal = short_score >= min_signals and (macd_cross_down or rsi_coming_dn or bb_bounce_high) and session_ok

var int last_dir = 0
long_clean  = long_signal  and last_dir != 1
short_clean = short_signal and last_dir != -1

if long_clean
    last_dir := 1
if short_clean
    last_dir := -1

// ─────────────────────────────────────────────
// ██  PLOTS — EMAs + BB
// ─────────────────────────────────────────────

plot(ema21,  "EMA 21",  color=color.new(color.yellow, 0), linewidth=1)
plot(ema50,  "EMA 50",  color=color.new(color.orange, 0), linewidth=1)
plot(ema200, "EMA 200", color=color.new(color.white, 30), linewidth=2)

p_upper = plot(bb_upper, "BB Upper", color=color.new(color.blue, 70), linewidth=1)
p_lower = plot(bb_lower, "BB Lower", color=color.new(color.blue, 70), linewidth=1)
fill(p_upper, p_lower, color=color.new(color.blue, 93))

// ─────────────────────────────────────────────
// ██  BACKGROUNDS
// ─────────────────────────────────────────────

bgcolor(show_bg ? (uptrend ? color.new(color.green, 95) : downtrend ? color.new(color.red, 95) : color.new(color.gray, 97)) : na, title="Trend BG")
bgcolor(use_session and in_session ? color.new(color.yellow, 96) : na, title="Session BG")

// ─────────────────────────────────────────────
// ██  SIGNAL ARROWS
// ─────────────────────────────────────────────

plotshape(long_clean,  "LONG",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), size=size.normal)
plotshape(short_clean, "SHORT", shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.normal)

// ─────────────────────────────────────────────
// ██  SIGNAL LABELS
//     KEY FIX: barstate.isconfirmed prevents label
//     duplication on intra-bar ticks and chart scrolling
// ─────────────────────────────────────────────

if show_labels and long_clean and barstate.isconfirmed
    label.new(bar_index, low - atr * 0.5,
      text      = "🟢 LONG\n✅ " + str.tostring(long_score) + "/5\nSL: " + str.tostring(math.round(close - atr * sl_atr_mult, 1)) + "\nTP: " + str.tostring(math.round(close + atr * tp_atr_mult, 1)),
      style     = label.style_label_up,
      color     = color.new(color.green, 10),
      textcolor = color.white,
      size      = size.normal)

if show_labels and short_clean and barstate.isconfirmed
    label.new(bar_index, high + atr * 0.5,
      text      = "🔴 SHORT\n✅ " + str.tostring(short_score) + "/5\nSL: " + str.tostring(math.round(close + atr * sl_atr_mult, 1)) + "\nTP: " + str.tostring(math.round(close - atr * tp_atr_mult, 1)),
      style     = label.style_label_down,
      color     = color.new(color.red, 10),
      textcolor = color.white,
      size      = size.normal)

// ─────────────────────────────────────────────
// ██  TP / SL LINES
//     KEY FIX 1: bar_index + 500 so lines extend far right
//     KEY FIX 2: xloc.bar_index anchors them to chart bars
//     so they never detach when you scroll
// ─────────────────────────────────────────────

var line sl_line = na
var line tp_line = na

if show_tp_sl and long_clean and barstate.isconfirmed
    line.delete(sl_line)
    line.delete(tp_line)
    sl_line := line.new(bar_index, close - atr * sl_atr_mult, bar_index + 500, close - atr * sl_atr_mult,
      xloc=xloc.bar_index, color=color.new(color.red,   20), style=line.style_dashed, width=1)
    tp_line := line.new(bar_index, close + atr * tp_atr_mult, bar_index + 500, close + atr * tp_atr_mult,
      xloc=xloc.bar_index, color=color.new(color.green, 20), style=line.style_dashed, width=1)

if show_tp_sl and short_clean and barstate.isconfirmed
    line.delete(sl_line)
    line.delete(tp_line)
    sl_line := line.new(bar_index, close + atr * sl_atr_mult, bar_index + 500, close + atr * sl_atr_mult,
      xloc=xloc.bar_index, color=color.new(color.red,   20), style=line.style_dashed, width=1)
    tp_line := line.new(bar_index, close - atr * tp_atr_mult, bar_index + 500, close - atr * tp_atr_mult,
      xloc=xloc.bar_index, color=color.new(color.green, 20), style=line.style_dashed, width=1)

// ─────────────────────────────────────────────
// ██  4H REMINDER LABEL
//     KEY FIX: var label + label.delete() ensures only
//     ONE label ever exists — moves correctly with chart
// ─────────────────────────────────────────────

var label hint_lbl = na
if show_htf_hint and barstate.islast
    label.delete(hint_lbl)
    hint_lbl := label.new(
      x         = bar_index,
      y         = close,
      text      = "⚠️ Always check\n4H trend first!",
      style     = label.style_label_lower_left,
      color     = color.new(color.orange, 15),
      textcolor = color.white,
      size      = size.small,
      xloc      = xloc.bar_index,
      yloc      = yloc.price)

// ─────────────────────────────────────────────
// ██  DASHBOARD TABLE
//     Table uses position.top_right which is always
//     fixed to the visible screen — never detaches
// ─────────────────────────────────────────────

var table dash = table.new(position.top_right, 2, 11,
  border_width = 1,
  frame_color  = color.new(color.navy, 20),
  frame_width  = 2)

if show_dash and barstate.islast
    table.cell(dash, 0, 0, "📊 DAY TRADING DASHBOARD",
      bgcolor=color.new(color.navy,0), text_color=color.white, text_size=size.normal)
    table.cell(dash, 1, 0, "STATUS",
      bgcolor=color.new(color.navy,0), text_color=color.white, text_size=size.normal)

    table.cell(dash, 0, 1, "1H Trend", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 1,
      uptrend ? "🟢 BULL" : downtrend ? "🔴 BEAR" : "⚪ NEUTRAL",
      bgcolor    = uptrend ? color.new(color.green,65) : downtrend ? color.new(color.red,65) : color.new(color.gray,65),
      text_color = color.black)

    table.cell(dash, 0, 2, "Session", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 2,
      not use_session ? "All Hours" : in_session ? "🟢 ACTIVE" : "🔴 OFF-HOURS",
      bgcolor    = not use_session ? color.new(color.gray,65) : in_session ? color.new(color.green,65) : color.new(color.red,65),
      text_color = color.black)

    table.cell(dash, 0, 3, "RSI (" + str.tostring(rsi_len) + ")", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 3,
      str.tostring(math.round(rsi,1)) + (rsi > rsi_ob ? " ⚠️OB" : rsi < rsi_os ? " ⚠️OS" : ""),
      bgcolor    = rsi > rsi_ob ? color.new(color.orange,65) : rsi < rsi_os ? color.new(color.aqua,65) : color.new(color.gray,65),
      text_color = color.black)

    table.cell(dash, 0, 4, "MACD", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 4,
      macd_bull ? "🟢 Bullish" : "🔴 Bearish",
      bgcolor    = macd_bull ? color.new(color.green,65) : color.new(color.red,65),
      text_color = color.black)

    table.cell(dash, 0, 5, "BB Position", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 5,
      close > bb_upper ? "Above Upper" : close < bb_lower ? "Below Lower" : "Inside Band",
      bgcolor    = close > bb_upper ? color.new(color.orange,65) : close < bb_lower ? color.new(color.aqua,65) : color.new(color.gray,65),
      text_color = color.black)

    table.cell(dash, 0, 6, "Volume", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 6,
      vol_ok ? "🟢 High" : "⚪ Normal",
      bgcolor    = vol_ok ? color.new(color.green,65) : color.new(color.gray,65),
      text_color = color.black)

    table.cell(dash, 0, 7, "🟢 Long Score", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 7,
      str.tostring(long_score) + " / 5",
      bgcolor    = long_score >= min_signals ? color.new(color.green,50) : color.new(color.gray,80),
      text_color = color.black)

    table.cell(dash, 0, 8, "🔴 Short Score", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 8,
      str.tostring(short_score) + " / 5",
      bgcolor    = short_score >= min_signals ? color.new(color.red,50) : color.new(color.gray,80),
      text_color = color.black)

    table.cell(dash, 0, 9, "ATR", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(dash, 1, 9,
      str.tostring(math.round(atr, 2)),
      bgcolor=color.new(color.gray,80), text_color=color.black)

    table.cell(dash, 0, 10, "⚡ Signal", bgcolor=color.new(color.navy,0), text_color=color.white)
    table.cell(dash, 1, 10,
      long_clean ? "🟢 BUY NOW" : short_clean ? "🔴 SELL NOW" : "⏳ WAITING",
      bgcolor    = long_clean ? color.new(color.green,35) : short_clean ? color.new(color.red,35) : color.new(color.gray,60),
      text_color = color.black)

// ─────────────────────────────────────────────
// ██  ALERTS
// ─────────────────────────────────────────────

alertcondition(long_clean,  "🟢 BTC LONG [1H Day Trade]",  "BTC/USDT 1H — LONG SIGNAL\nPrice: {{close}}\n✅ Enter on next candle open\n⚠️ Confirm 4H trend is BULLISH")
alertcondition(short_clean, "🔴 BTC SHORT [1H Day Trade]", "BTC/USDT 1H — SHORT SIGNAL\nPrice: {{close}}\n✅ Enter on next candle open\n⚠️ Confirm 4H trend is BEARISH")
alertcondition(long_clean or short_clean, "⚡ Any BTC Signal", "BTC/USDT — Signal at {{close}} | Use Once Per Bar Close")

// ─────────────────────────────────────────────
// END — BTC Day Trading V1.3 (Chart-Stable Fix)
// ─────────────────────────────────────────────
