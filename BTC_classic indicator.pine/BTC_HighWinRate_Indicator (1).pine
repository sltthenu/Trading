// ============================================================
// BTC/USDT Day Trading Optimized Indicator (60%+ Win Rate)
// Combines: EMA Trend + RSI + MACD + Bollinger Bands + Volume
// Optimized for: DAY TRADING | Primary: 1H | Confirm: 4H
// Best Hours: NY Open 13:00–17:00 UTC | London 07:00–10:00 UTC
// ============================================================

//@version=5
indicator(title="BTC Day Trading Signals [1H Optimized]", shorttitle="BTC-DT1H", overlay=true, max_bars_back=500)

// ─────────────────────────────────────────────
// ██  INPUTS
// ─────────────────────────────────────────────

// EMA Settings
ema_fast     = input.int(21,  "Fast EMA",        group="📈 Trend Filter (EMA)")
ema_mid      = input.int(50,  "Mid EMA",         group="📈 Trend Filter (EMA)")
ema_slow     = input.int(200, "Slow EMA",        group="📈 Trend Filter (EMA)")

// RSI Settings
rsi_len      = input.int(14,  "RSI Length",      group="📊 RSI Settings")
rsi_ob       = input.int(70,  "Overbought",      group="📊 RSI Settings", tooltip="Day Trading: 70 is less sensitive, filters noise on 1H")
rsi_os       = input.int(30,  "Oversold",        group="📊 RSI Settings", tooltip="Day Trading: 30 is less sensitive, filters noise on 1H")

// MACD Settings
macd_fast    = input.int(12,  "MACD Fast",       group="⚡ MACD Settings")
macd_slow    = input.int(26,  "MACD Slow",       group="⚡ MACD Settings")
macd_signal  = input.int(9,   "MACD Signal",     group="⚡ MACD Settings")

// Bollinger Bands
bb_len       = input.int(20,  "BB Length",       group="🎯 Bollinger Bands")
bb_mult      = input.float(2.0,"BB Multiplier",  group="🎯 Bollinger Bands")

// Volume Filter
vol_ma_len   = input.int(20,  "Volume MA Length",group="📦 Volume Filter")
vol_mult     = input.float(1.5,"Min Volume Mult",group="📦 Volume Filter", tooltip="Day Trading: 1.5× average = stricter volume confirmation")

// Signal Confirmation
min_signals  = input.int(3,   "Min Confirmations (2–4)", minval=2, maxval=4, group="✅ Signal Quality")
show_labels  = input.bool(true,"Show Signal Labels",      group="🖥 Display")
show_bg      = input.bool(true,"Show Trend Background",   group="🖥 Display")
show_tp_sl   = input.bool(true,"Show TP / SL Lines",      group="🖥 Display")

// Risk Management
atr_len      = input.int(14,  "ATR Length",      group="🛡 Risk Management")
sl_atr_mult  = input.float(1.2,"Stop Loss (ATR ×)",group="🛡 Risk Management", tooltip="Day Trading: 1.2× = tighter stop for 1H candles")
tp_atr_mult  = input.float(2.5,"Take Profit (ATR ×)",group="🛡 Risk Management", tooltip="Day Trading: 2.5× = realistic TP on 1H, gives ~2:1 R:R")

// Day Trading Session Filter
use_session  = input.bool(true, "Filter by High-Volume Sessions", group="⏰ Session Filter (UTC)")
session_1    = input.session("0700-1000", "London Open (UTC)",    group="⏰ Session Filter (UTC)")
session_2    = input.session("1300-1700", "NY Open / Overlap (UTC)", group="⏰ Session Filter (UTC)")

// 4H Trend Confirmation Hint
show_htf_hint = input.bool(true, "Show 4H Trend Reminder Label", group="🖥 Display")

// ─────────────────────────────────────────────
// ██  CALCULATIONS
// ─────────────────────────────────────────────

// EMAs
ema21  = ta.ema(close, ema_fast)
ema50  = ta.ema(close, ema_mid)
ema200 = ta.ema(close, ema_slow)

// RSI
rsi    = ta.rsi(close, rsi_len)

// MACD
[macdLine, signalLine, histLine] = ta.macd(close, macd_fast, macd_slow, macd_signal)
macd_bull = macdLine > signalLine
macd_bear = macdLine < signalLine
macd_cross_up   = ta.crossover(macdLine, signalLine)
macd_cross_down = ta.crossunder(macdLine, signalLine)

// Bollinger Bands
bb_basis = ta.sma(close, bb_len)
bb_dev   = bb_mult * ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_width = (bb_upper - bb_lower) / bb_basis

// Volume
vol_ma   = ta.sma(volume, vol_ma_len)
vol_ok   = volume > vol_ma * vol_mult

// ATR for SL/TP
atr      = ta.atr(atr_len)

// ─────────────────────────────────────────────
// ██  SESSION FILTER (Day Trading)
//     Signals only fire during high-volume windows
// ─────────────────────────────────────────────

in_london   = time(timeframe.period, session_1, "UTC")
in_ny       = time(timeframe.period, session_2, "UTC")
in_session  = not na(in_london) or not na(in_ny)
session_ok  = use_session ? in_session : true

// Trend Direction
uptrend   = ema21 > ema50 and ema50 > ema200
downtrend = ema21 < ema50 and ema50 < ema200

// Price vs EMAs
price_above = close > ema21 and close > ema50
price_below = close < ema21 and close < ema50

// RSI conditions
rsi_bull_zone  = rsi > 50 and rsi < rsi_ob
rsi_bear_zone  = rsi < 50 and rsi > rsi_os
rsi_coming_up  = ta.crossover(rsi, 50)
rsi_coming_dn  = ta.crossunder(rsi, 50)
rsi_bounce     = rsi < 45 and rsi > rsi_os  // oversold bounce

// Bollinger Band conditions
bb_squeeze     = bb_width < ta.sma(bb_width, 20) * 0.8  // squeeze = low volatility
bb_bounce_low  = low <= bb_lower and close > bb_lower     // bounced off lower band
bb_bounce_high = high >= bb_upper and close < bb_upper    // rejected from upper band
bb_breakout_up = close > bb_upper and close[1] <= bb_upper[1]
bb_breakout_dn = close < bb_lower and close[1] >= bb_lower[1]

// ─────────────────────────────────────────────
// ██  CONFIRMATION SCORE SYSTEM
//     Each condition = 1 point (max 5 for each direction)
//     Signal fires when score >= min_signals
// ─────────────────────────────────────────────

// LONG confirmations
long_c1 = uptrend              ? 1 : 0   // EMA stack bullish
long_c2 = price_above          ? 1 : 0   // Price above key EMAs
long_c3 = rsi_bull_zone or rsi_bounce ? 1 : 0  // RSI healthy
long_c4 = macd_bull            ? 1 : 0   // MACD bullish
long_c5 = (bb_bounce_low or bb_breakout_up) and vol_ok ? 1 : 0  // BB + Volume confirm

long_score = long_c1 + long_c2 + long_c3 + long_c4 + long_c5

// SHORT confirmations
short_c1 = downtrend           ? 1 : 0   // EMA stack bearish
short_c2 = price_below         ? 1 : 0   // Price below key EMAs
short_c3 = rsi_bear_zone       ? 1 : 0   // RSI in bearish zone
short_c4 = macd_bear           ? 1 : 0   // MACD bearish
short_c5 = (bb_bounce_high or bb_breakout_dn) and vol_ok ? 1 : 0  // BB + Volume confirm

short_score = short_c1 + short_c2 + short_c3 + short_c4 + short_c5

// ─────────────────────────────────────────────
// ██  ENTRY SIGNALS
//     Additional trigger: MACD crossover as entry timing
// ─────────────────────────────────────────────

long_signal  = long_score  >= min_signals and (macd_cross_up   or rsi_coming_up  or bb_bounce_low)  and session_ok
short_signal = short_score >= min_signals and (macd_cross_down or rsi_coming_dn  or bb_bounce_high) and session_ok

// Prevent consecutive same-direction signals (reduce noise)
var int last_direction = 0  // 1 = last was long, -1 = last was short
long_signal_clean  = long_signal  and last_direction != 1
short_signal_clean = short_signal and last_direction != -1

if long_signal_clean
    last_direction := 1
if short_signal_clean
    last_direction := -1

// ─────────────────────────────────────────────
// ██  PLOTS — EMAs
// ─────────────────────────────────────────────

plot(ema21,  "EMA 21",  color=color.new(color.yellow, 0),  linewidth=1)
plot(ema50,  "EMA 50",  color=color.new(color.orange, 0),  linewidth=1)
plot(ema200, "EMA 200", color=color.new(color.white,  30), linewidth=2)

// Bollinger Bands
p_bb_upper = plot(bb_upper, "BB Upper", color=color.new(color.blue, 70), linewidth=1)
p_bb_lower = plot(bb_lower, "BB Lower", color=color.new(color.blue, 70), linewidth=1)
fill(p_bb_upper, p_bb_lower, color=color.new(color.blue, 93))

// ─────────────────────────────────────────────
// ██  BACKGROUND — TREND COLOR
// ─────────────────────────────────────────────

bg_color = show_bg ? (uptrend ? color.new(color.green, 95) : downtrend ? color.new(color.red, 95) : color.new(color.gray, 97)) : na
bgcolor(bg_color, title="Trend Background")

// Session Highlight
session_bg = use_session and in_session ? color.new(color.yellow, 96) : na
bgcolor(session_bg, title="Active Trading Session")

// 4H Trend Reminder (top left)
if show_htf_hint and barstate.islast
    label.new(bar_index, ta.highest(high, 10),
      text="⚠️ Check 4H trend\nbefore entering!",
      style=label.style_label_lower_right,
      color=color.new(color.orange, 20),
      textcolor=color.white,
      size=size.small)



plotshape(long_signal_clean,  title="LONG Signal",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime,  0), size=size.normal, text="")
plotshape(short_signal_clean, title="SHORT Signal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,   0), size=size.normal, text="")

// ─────────────────────────────────────────────
// ██  SIGNAL LABELS WITH SCORE
// ─────────────────────────────────────────────

if show_labels and long_signal_clean
    label.new(bar_index, low - atr * 0.5,
      text="🟢 LONG\n✅ " + str.tostring(long_score) + "/5 confirms\nSL: " + str.tostring(math.round(close - atr * sl_atr_mult, 2)) + "\nTP: " + str.tostring(math.round(close + atr * tp_atr_mult, 2)),
      style=label.style_label_up,
      color=color.new(color.green, 10),
      textcolor=color.white,
      size=size.normal)

if show_labels and short_signal_clean
    label.new(bar_index, high + atr * 0.5,
      text="🔴 SHORT\n✅ " + str.tostring(short_score) + "/5 confirms\nSL: " + str.tostring(math.round(close + atr * sl_atr_mult, 2)) + "\nTP: " + str.tostring(math.round(close - atr * tp_atr_mult, 2)),
      style=label.style_label_down,
      color=color.new(color.red, 10),
      textcolor=color.white,
      size=size.normal)

// ─────────────────────────────────────────────
// ██  TP / SL DYNAMIC LINES
// ─────────────────────────────────────────────

var line sl_line = na
var line tp_line = na

if show_tp_sl and long_signal_clean
    line.delete(sl_line)
    line.delete(tp_line)
    sl_line := line.new(bar_index, close - atr * sl_atr_mult, bar_index + 20, close - atr * sl_atr_mult, color=color.red,   style=line.style_dashed, width=1)
    tp_line := line.new(bar_index, close + atr * tp_atr_mult, bar_index + 20, close + atr * tp_atr_mult, color=color.green, style=line.style_dashed, width=1)

if show_tp_sl and short_signal_clean
    line.delete(sl_line)
    line.delete(tp_line)
    sl_line := line.new(bar_index, close + atr * sl_atr_mult, bar_index + 20, close + atr * sl_atr_mult, color=color.red,   style=line.style_dashed, width=1)
    tp_line := line.new(bar_index, close - atr * tp_atr_mult, bar_index + 20, close - atr * tp_atr_mult, color=color.green, style=line.style_dashed, width=1)

// ─────────────────────────────────────────────
// ██  INFO TABLE — Live Score Dashboard
// ─────────────────────────────────────────────

var table info = table.new(position.top_right, 2, 11, border_width=1)

if barstate.islast
    // Header
    table.cell(info, 0, 0, "📊 DAY TRADING DASHBOARD",  bgcolor=color.new(color.navy,10),  text_color=color.white, text_size=size.normal)
    table.cell(info, 1, 0, "STATUS",                    bgcolor=color.new(color.navy,10),  text_color=color.white, text_size=size.normal)

    // Trend
    table.cell(info, 0, 1, "1H Trend",               bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 1, uptrend ? "🟢 BULL" : downtrend ? "🔴 BEAR" : "⚪ NEUTRAL",
      bgcolor=uptrend ? color.new(color.green,70) : downtrend ? color.new(color.red,70) : color.new(color.gray,70),
      text_color=color.black)

    // Session
    table.cell(info, 0, 2, "Session",                bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 2, not use_session ? "All Hours" : in_session ? "🟢 ACTIVE" : "🔴 OFF-HOURS",
      bgcolor=not use_session ? color.new(color.gray,70) : in_session ? color.new(color.green,70) : color.new(color.red,80),
      text_color=color.black)

    // RSI
    table.cell(info, 0, 3, "RSI (" + str.tostring(rsi_len) + ")", bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 3, str.tostring(math.round(rsi, 1)) + (rsi > rsi_ob ? " ⚠️OB" : rsi < rsi_os ? " ⚠️OS" : ""),
      bgcolor=rsi > rsi_ob ? color.new(color.orange,70) : rsi < rsi_os ? color.new(color.aqua,70) : color.new(color.gray,70),
      text_color=color.black)

    // MACD
    table.cell(info, 0, 4, "MACD",                bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 4, macd_bull ? "🟢 Bullish" : "🔴 Bearish",
      bgcolor=macd_bull ? color.new(color.green,70) : color.new(color.red,70),
      text_color=color.black)

    // BB Position
    table.cell(info, 0, 5, "BB Position",         bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 5, close > bb_upper ? "Above Upper" : close < bb_lower ? "Below Lower" : "Inside Band",
      bgcolor=close > bb_upper ? color.new(color.orange,70) : close < bb_lower ? color.new(color.aqua,70) : color.new(color.gray,70),
      text_color=color.black)

    // Volume
    table.cell(info, 0, 6, "Volume",              bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 6, vol_ok ? "🟢 High" : "⚪ Normal",
      bgcolor=vol_ok ? color.new(color.green,70) : color.new(color.gray,70),
      text_color=color.black)

    // Long Score
    table.cell(info, 0, 7, "🟢 Long Score",       bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 7, str.tostring(long_score) + " / 5",
      bgcolor=long_score >= min_signals ? color.new(color.green,60) : color.new(color.gray,80),
      text_color=color.black)

    // Short Score
    table.cell(info, 0, 8, "🔴 Short Score",      bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 8, str.tostring(short_score) + " / 5",
      bgcolor=short_score >= min_signals ? color.new(color.red,60) : color.new(color.gray,80),
      text_color=color.black)

    // ATR
    table.cell(info, 0, 9, "ATR (SL/TP ref)",    bgcolor=color.new(color.gray,80), text_color=color.black)
    table.cell(info, 1, 9, str.tostring(math.round(atr, 2)),
      bgcolor=color.new(color.gray,80), text_color=color.black)

    // Signal
    table.cell(info, 0, 10, "⚡ Signal",           bgcolor=color.new(color.navy,10), text_color=color.white)
    table.cell(info, 1, 10,
      long_signal_clean ? "🟢 BUY NOW" : short_signal_clean ? "🔴 SELL NOW" : "⏳ WAITING",
      bgcolor=long_signal_clean ? color.new(color.green,40) : short_signal_clean ? color.new(color.red,40) : color.new(color.gray,60),
      text_color=color.black)

// ─────────────────────────────────────────────
// ██  ALERTS
// ─────────────────────────────────────────────

alertcondition(long_signal_clean,  title="🟢 BTC LONG Signal [1H Day Trade]",  message="BTC/USDT 1H — DAY TRADE LONG SIGNAL\nPrice: {{close}}\n✅ Enter on next candle open\n⚠️ Confirm 4H trend is BULLISH first!")
alertcondition(short_signal_clean, title="🔴 BTC SHORT Signal [1H Day Trade]", message="BTC/USDT 1H — DAY TRADE SHORT SIGNAL\nPrice: {{close}}\n✅ Enter on next candle open\n⚠️ Confirm 4H trend is BEARISH first!")
alertcondition(long_signal_clean or short_signal_clean, title="⚡ Any BTC Day Trade Signal", message="BTC/USDT 1H — New Day Trade Signal at {{close}} | Set alert to 'Once Per Bar Close'")

// ─────────────────────────────────────────────
// END OF SCRIPT
// ─────────────────────────────────────────────
