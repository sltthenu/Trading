//@version=5
indicator("SMC Institutional Flow Pro v2.6", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=200)

// ═══════════════════════════════════════════════════════════
//  INPUTS
// ═══════════════════════════════════════════════════════════
grp1 = "Market Structure"
showSMC      = input.bool(true,  "Show BOS/CHoCH Labels",           group=grp1)
swingLen     = input.int(5,      "Swing Pivot Length",   minval=3,   group=grp1)

grp2 = "Timeframes"
htfTF        = input.timeframe("D",   "HTF1 — Daily (Master Bias)",  group=grp2)
trendTF      = input.timeframe("240", "HTF2 — 4H (Trend Filter)",    group=grp2)
trendTF2     = input.timeframe("60",  "MTF  — 1H (Momentum)",        group=grp2)
smaLen       = input.int(50,  "Trend SMA Length",                    group=grp2)
emaFastLen   = input.int(8,   "EMA Fast",                            group=grp2)
emaSlowLen   = input.int(21,  "EMA Slow",                            group=grp2)

grp3 = "Order Blocks & FVG"
showOB       = input.bool(true, "Show Order Blocks",                 group=grp3)
showFVG      = input.bool(true, "Show Fair Value Gaps",              group=grp3)
obMitigation = input.int(3,     "OB Extension Bars",                 group=grp3)

grp4 = "Liquidity"
showLiqPool  = input.bool(true, "Show Liquidity Pools",              group=grp4)
liqLen       = input.int(20,    "Liquidity Lookback",                group=grp4)
volMulti     = input.float(1.5, "Volume Spike Multiplier",           group=grp4)

grp5 = "Risk Management"
atrLength    = input.int(14,    "ATR Length",                        group=grp5)
atrMult_sl   = input.float(1.5, "ATR SL Multiplier",                 group=grp5)
rrRatio      = input.float(2.5, "Risk:Reward Ratio",                  group=grp5)

grp6 = "Signal Filters"
// Raised to 5 — at 4/7 the system fires too many counter-trend pullbacks
minConfluence    = input.int(5,  "Min Score (5=quality, 6=premium)",  group=grp6, minval=4, maxval=7)
rsiLen           = input.int(14, "RSI Length",                        group=grp6)
rsiHardBuyBlock  = input.int(30, "RSI Hard Block BUY  below",         group=grp6, minval=10, maxval=45)
rsiHardSellBlock = input.int(70, "RSI Hard Block SELL above",         group=grp6, minval=55, maxval=90)
rsiBullZoneLow   = input.int(45, "RSI Bull Zone (score +1 if above)", group=grp6)
rsiBearZoneHigh  = input.int(55, "RSI Bear Zone (score +1 if below)", group=grp6)
showScore        = input.bool(true, "Show Score Labels",              group=grp6)

// ═══════════════════════════════════════════════════════════
//  CORE INDICATORS
// ═══════════════════════════════════════════════════════════
atr       = ta.atr(atrLength)
atr_pct   = atr / close * 100
volAvg    = ta.sma(volume, 20)
volSpike  = volume > volAvg * volMulti
rsi       = ta.rsi(close, rsiLen)

rsiHardBlockBuy  = rsi < rsiHardBuyBlock
rsiHardBlockSell = rsi > rsiHardSellBlock
rsiBullOK = rsi >= rsiBullZoneLow  and rsi < rsiHardSellBlock
rsiBearOK = rsi <= rsiBearZoneHigh and rsi > rsiHardBuyBlock

// ═══════════════════════════════════════════════════════════
//  TREND EXHAUSTION FILTER
//
//  Problem: SELLs fire at $65K after a $20K drop — price already
//  exhausted. BUYs fire at $75K after $10K rally — same issue.
//
//  Fix: Measure how far price has moved from its N-bar mean.
//  If price is already stretched far from EMA in trend direction,
//  do NOT enter — wait for pullback/reset instead.
//
//  Also: Count consecutive same-direction candles. 5+ in a row
//  = exhaustion, not momentum. Block entries in that direction.
// ═══════════════════════════════════════════════════════════
ema50_curr   = ta.ema(close, 50)
pctFromEMA50 = (close - ema50_curr) / ema50_curr * 100

// Block SELL if price is already >4% below EMA50 (oversold stretch)
// Block BUY  if price is already >4% above EMA50 (overbought stretch)
stretchBlockSell = pctFromEMA50 < -4.0
stretchBlockBuy  = pctFromEMA50 >  4.0

// Count consecutive bearish / bullish candles
var int consecBear = 0
var int consecBull = 0
if close < open
    consecBear += 1
    consecBull := 0
else if close > open
    consecBull += 1
    consecBear := 0
else
    consecBear := 0
    consecBull := 0

// 5+ consecutive candles = exhaustion, block entries in that direction
exhaustionBlockSell = consecBear >= 5
exhaustionBlockBuy  = consecBull >= 5

// Momentum recency: require at least 1 same-direction candle in last 3
recentBullMom = close > open or close[1] > open[1] or close[2] > open[2]
recentBearMom = close < open or close[1] < open[1] or close[2] < open[2]

// ═══════════════════════════════════════════════════════════
//  TRIPLE TIMEFRAME TREND SYSTEM
//
//  CRITICAL FIX: All 3 TFs must agree for a signal to exist
//  Daily  = Master bias  (veto power — if Daily says NO, no signal)
//  4H     = Trend filter (must agree with Daily)
//  1H     = Momentum     (confirms entry direction)
//
//  Logic:
//  BUY  allowed ONLY when Daily ≥ neutral AND 4H bullish
//  SELL allowed ONLY when Daily ≤ neutral AND 4H bearish
// ═══════════════════════════════════════════════════════════

// --- Daily (Master Bias) ---
dClose = request.security(syminfo.tickerid, htfTF, close)
dSMA   = request.security(syminfo.tickerid, htfTF, ta.sma(close, smaLen))
dEMAf  = request.security(syminfo.tickerid, htfTF, ta.ema(close, emaFastLen))
dEMAs  = request.security(syminfo.tickerid, htfTF, ta.ema(close, emaSlowLen))
dEMA200= request.security(syminfo.tickerid, htfTF, ta.ema(close, 200))

// FIX: Removed strict EMA200 requirement from daily bull/bear
// EMA200 caused daily to show BEAR during normal bull pullbacks → missed all buys
// Now: daily bias = SMA50 + EMA alignment only (more responsive)
dailyBull = dClose > dSMA and dEMAf > dEMAs
dailyBear = dClose < dSMA and dEMAf < dEMAs
dailyNeut = not dailyBull and not dailyBear

// --- 4H (Trend) ---
h4Close = request.security(syminfo.tickerid, trendTF, close)
h4SMA   = request.security(syminfo.tickerid, trendTF, ta.sma(close, smaLen))
h4EMAf  = request.security(syminfo.tickerid, trendTF, ta.ema(close, emaFastLen))
h4EMAs  = request.security(syminfo.tickerid, trendTF, ta.ema(close, emaSlowLen))
h4EMA200= request.security(syminfo.tickerid, trendTF, ta.ema(close, 200))

h4Bull = h4Close > h4SMA and h4EMAf > h4EMAs
h4Bear = h4Close < h4SMA and h4EMAf < h4EMAs
h4Neut = not h4Bull and not h4Bear

// --- 1H (Momentum) ---
h1EMAf        = request.security(syminfo.tickerid, trendTF2, ta.ema(close, emaFastLen))
h1EMAs        = request.security(syminfo.tickerid, trendTF2, ta.ema(close, emaSlowLen))
h1MACD_line   = request.security(syminfo.tickerid, trendTF2, ta.ema(close, 12) - ta.ema(close, 26))
h1MACD_signal = request.security(syminfo.tickerid, trendTF2, ta.ema(ta.ema(close, 12) - ta.ema(close, 26), 9))

h1Bull = h1EMAf > h1EMAs and h1MACD_line > h1MACD_signal
h1Bear = h1EMAf < h1EMAs and h1MACD_line < h1MACD_signal

// ═══════════════════════════════════════════════════════════
//  TREND ALIGNMENT GATES
//
//  BUY  gate: Daily NOT bearish + 4H bullish  (both must be true)
//  SELL gate: Daily NOT bullish + 4H bearish  (both must be true)
//
//  This is the primary fix for the false BUY signals —
//  previously the system could fire BUY with 4H in NEUT/BEAR
// ═══════════════════════════════════════════════════════════
// v2.6 RANGING MARKET FIX:
// In a trending market Daily+4H agree → easy.
// In a ranging/correcting market Daily can be BEAR while price ranges
// $62K-$75K — blocking ALL buys is wrong and misses 21% rallies.
//
// New logic: 4H is the PRIMARY gate. Daily is a SCORE layer only.
// Hard veto ONLY if Daily + 4H + 1H all three agree in opposition.
// This allows counter-trend trades when 4H structure flips, while
// still scoring them lower (dailyBull/dailyBear = +1 score point).
trendAlignBuy  = h4Bull   // 4H bullish is sufficient for buy alignment
trendAlignSell = h4Bear   // 4H bearish is sufficient for sell alignment

// Hard veto: all three timeframes must oppose to block
hardVetoBuy  = dailyBear and h4Bear and h1Bear   // triple bear = no buy
hardVetoSell = dailyBull and h4Bull and h1Bull   // triple bull = no sell

// ═══════════════════════════════════════════════════════════
//  MARKET STRUCTURE — BOS / CHoCH
// ═══════════════════════════════════════════════════════════
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low,  swingLen, swingLen)

var float lastHH = na
var float lastLL = na
var float lastLH = na
var float lastHL = na

if not na(ph)
    if na(lastHH) or ph > lastHH
        lastHH := ph
    else
        lastLH := ph

if not na(pl)
    if na(lastLL) or pl < lastLL
        lastLL := pl
    else
        lastHL := pl

bosUp     = not na(lastHH) and ta.crossover(close,  lastHH)
bosDown   = not na(lastLL) and ta.crossunder(close, lastLL)
chochUp   = not na(lastLH) and ta.crossover(close,  lastLH) and not bosUp
chochDown = not na(lastHL) and ta.crossunder(close, lastHL) and not bosDown

// Fire label once per event
var int chochUpCount   = 0
var int chochDownCount = 0
if chochUp
    chochUpCount   += 1
    chochDownCount := 0
else if chochDown
    chochDownCount += 1
    chochUpCount   := 0
else if bosUp or bosDown
    chochUpCount   := 0
    chochDownCount := 0

chochUpFired   = chochUpCount   == 1
chochDownFired = chochDownCount == 1

structureBull = bosUp   or chochUpFired
structureBear = bosDown or chochDownFired

if showSMC and bosUp
    label.new(bar_index, high, "BOS ▲", color=color.new(color.green,20), textcolor=color.white, style=label.style_label_down, size=size.tiny)
if showSMC and bosDown
    label.new(bar_index, low,  "BOS ▼", color=color.new(color.red,20),   textcolor=color.white, style=label.style_label_up,   size=size.tiny)
if showSMC and chochUpFired
    label.new(bar_index, high, "CHoCH", color=color.new(color.lime,30),  textcolor=color.black, style=label.style_label_down, size=size.tiny)
if showSMC and chochDownFired
    label.new(bar_index, low,  "CHoCH", color=color.new(color.orange,30),textcolor=color.black, style=label.style_label_up,   size=size.tiny)

// ═══════════════════════════════════════════════════════════
//  ORDER BLOCKS
// ═══════════════════════════════════════════════════════════
isBearCandle = close[1] < open[1]
isBullMove   = close > open and (close - open) > atr * 0.8
isBullCandle = close[1] > open[1]
isBearMove   = close < open and (open - close) > atr * 0.8

var float obBullTop = na
var float obBullBot = na
var box   obBullBox = na
var float obBearTop = na
var float obBearBot = na
var box   obBearBox = na

if showOB and isBullMove and isBearCandle
    obBullTop := high[1]
    obBullBot := low[1]
    if not na(obBullBox)
        box.delete(obBullBox)
    obBullBox := box.new(bar_index-1, obBullTop, bar_index+obMitigation, obBullBot,
      border_color=color.new(color.green,50), bgcolor=color.new(color.green,85))

if showOB and isBearMove and isBullCandle
    obBearTop := high[1]
    obBearBot := low[1]
    if not na(obBearBox)
        box.delete(obBearBox)
    obBearBox := box.new(bar_index-1, obBearTop, bar_index+obMitigation, obBearBot,
      border_color=color.new(color.red,50), bgcolor=color.new(color.red,85))

inBullOB = not na(obBullTop) and close <= obBullTop and close >= obBullBot
inBearOB = not na(obBearTop) and close >= obBearBot and close <= obBearTop

// ═══════════════════════════════════════════════════════════
//  FAIR VALUE GAPS
// ═══════════════════════════════════════════════════════════
bullFVG = showFVG and low > high[2] and close[1] > open[1]
bearFVG = showFVG and high < low[2] and close[1] < open[1]

if bullFVG
    box.new(bar_index-2, low,  bar_index, high[2],
      border_color=color.new(color.teal,60),    bgcolor=color.new(color.teal,88))
if bearFVG
    box.new(bar_index-2, high, bar_index, low[2],
      border_color=color.new(color.fuchsia,60), bgcolor=color.new(color.fuchsia,88))

// ═══════════════════════════════════════════════════════════
//  LIQUIDITY POOLS & SWEEPS
// ═══════════════════════════════════════════════════════════
eqHighThresh = atr * 0.3
eqLowThresh  = atr * 0.3

eqHigh = showLiqPool and math.abs(high - high[liqLen]) < eqHighThresh and high == ta.highest(high, liqLen)
eqLow  = showLiqPool and math.abs(low  - low[liqLen])  < eqLowThresh  and low  == ta.lowest(low, liqLen)

if eqHigh
    line.new(bar_index-liqLen, high, bar_index, high,
      color=color.new(color.yellow,30), style=line.style_dotted, width=2)
    label.new(bar_index, high + atr*0.3, "BSL 💧",
      color=color.new(color.yellow,50), textcolor=color.black, style=label.style_label_down, size=size.tiny)

if eqLow
    line.new(bar_index-liqLen, low, bar_index, low,
      color=color.new(color.orange,30), style=line.style_dotted, width=2)
    label.new(bar_index, low - atr*0.3, "SSL 💧",
      color=color.new(color.orange,50), textcolor=color.white, style=label.style_label_up, size=size.tiny)

liqSweepUp   = low  < ta.lowest(low,   liqLen)[1] and close > ta.lowest(low,   liqLen)[1]
liqSweepDown = high > ta.highest(high, liqLen)[1] and close < ta.highest(high, liqLen)[1]

// ═══════════════════════════════════════════════════════════
//  VOLUME DELTA
// ═══════════════════════════════════════════════════════════
buyVolProxy  = (close > open) ? volume * ((close - open) / (high - low + 0.0001)) : 0.0
sellVolProxy = (close < open) ? volume * ((open - close) / (high - low + 0.0001)) : 0.0
volDelta     = buyVolProxy - sellVolProxy
volDeltaSma  = ta.sma(volDelta, 10)
strongBuyVol  = volDelta > 0 and volDelta > volDeltaSma * 1.5 and volSpike
strongSellVol = volDelta < 0 and volDelta < volDeltaSma * 1.5 and volSpike

// ═══════════════════════════════════════════════════════════
//  CONFLUENCE SCORING — 8 LAYERS (added Daily bias as layer)
//
//  [1] Daily bias aligned       ← NEW layer replaces old HTF single check
//  [2] 4H trend aligned
//  [3] 1H momentum aligned
//  [4] Market structure (BOS/CHoCH)
//  [5] Order Block
//  [6] Liquidity sweep
//  [7] Volume delta
//  [8] RSI zone
// ═══════════════════════════════════════════════════════════
buyScore = 0
buyScore += dailyBull      ? 1 : 0   // [1] Daily bullish
buyScore += h4Bull         ? 1 : 0   // [2] 4H bullish
buyScore += h1Bull         ? 1 : 0   // [3] 1H momentum up
buyScore += structureBull  ? 1 : 0   // [4] Structure break up
buyScore += inBullOB       ? 1 : 0   // [5] In bullish OB
buyScore += liqSweepUp     ? 1 : 0   // [6] Liq sweep
buyScore += strongBuyVol   ? 1 : 0   // [7] Volume confirms
buyScore += rsiBullOK      ? 1 : 0   // [8] RSI in range

sellScore = 0
sellScore += dailyBear     ? 1 : 0
sellScore += h4Bear        ? 1 : 0
sellScore += h1Bear        ? 1 : 0
sellScore += structureBear ? 1 : 0
sellScore += inBearOB      ? 1 : 0
sellScore += liqSweepDown  ? 1 : 0
sellScore += strongSellVol ? 1 : 0
sellScore += rsiBearOK     ? 1 : 0

// ═══════════════════════════════════════════════════════════
//  CANDLE CONFIRMATION
// ═══════════════════════════════════════════════════════════
bullEngulf = close > open[1] and open < close[1] and close > open
bearEngulf = close < open[1] and open > close[1] and close < open
bullPinBar = (high - close) < (close - low) * 0.33  and (close - low)  > atr * 0.6
bearPinBar = (close - low)  < (high - close) * 0.33 and (high - close) > atr * 0.6

bullCandleConf = bullEngulf or bullPinBar
bearCandleConf = bearEngulf or bearPinBar

// ═══════════════════════════════════════════════════════════
//  SIGNAL COOLDOWN & DEDUPLICATION
//
//  Problem: multiple signals cluster in same zone (5-6 SELLs)
//  Fix 1: bar cooldown — no re-fire within N bars
//  Fix 2: price cooldown — no re-fire within 1.5×ATR of last signal
//  Fix 3: opposite signal resets cooldown immediately
// ═══════════════════════════════════════════════════════════
cooldownBars = 8

var int   lastBuyBar    = -99
var int   lastSellBar   = -99
var float lastBuyPrice  = na
var float lastSellPrice = na

buyCooldownOK  = (bar_index - lastBuyBar)  >= cooldownBars
sellCooldownOK = (bar_index - lastSellBar) >= cooldownBars
buyPriceOK     = na(lastBuyPrice)  or math.abs(close - lastBuyPrice)  > atr * 1.5
sellPriceOK    = na(lastSellPrice) or math.abs(close - lastSellPrice) > atr * 1.5

// ═══════════════════════════════════════════════════════════
//  FINAL SIGNAL — 6 GATES MUST ALL PASS
//
//  Gate A: Score >= minConfluence (out of 8)
//  Gate B: Trend alignment (Daily + 4H agree)
//  Gate C: No hard veto (both Daily+4H opposing)
//  Gate D: RSI not at extreme
//  Gate E: Candle confirmation pattern
//  Gate F: Cooldown (bar distance + price distance)
// ═══════════════════════════════════════════════════════════
bullishSignal = buyScore  >= minConfluence
             and trendAlignBuy
             and not hardVetoBuy
             and not rsiHardBlockBuy
             and not stretchBlockBuy       // not already >4% above EMA50
             and not exhaustionBlockBuy    // not 5+ consecutive bull candles
             and recentBullMom             // at least 1 bull candle in last 3
             and bullCandleConf
             and buyCooldownOK
             and buyPriceOK

bearishSignal = sellScore >= minConfluence
             and trendAlignSell
             and not hardVetoSell
             and not rsiHardBlockSell
             and not stretchBlockSell      // not already >4% below EMA50
             and not exhaustionBlockSell   // not 5+ consecutive bear candles
             and recentBearMom             // at least 1 bear candle in last 3
             and bearCandleConf
             and sellCooldownOK
             and sellPriceOK

if bullishSignal
    lastBuyBar   := bar_index
    lastBuyPrice := close
    lastSellBar  := -99   // opposite signal resets sell cooldown

if bearishSignal
    lastSellBar   := bar_index
    lastSellPrice := close
    lastBuyBar    := -99  // opposite signal resets buy cooldown

// ═══════════════════════════════════════════════════════════
//  ADAPTIVE SL / TP
// ═══════════════════════════════════════════════════════════
// FIX: SL uses 2.0× ATR (was 1.5×) — 1.5× too tight, normal retracements hit SL
// OB-anchored SL adds buffer of full ATR (was 0.3×)
float buySL  = inBullOB and not na(obBullBot) ? obBullBot - atr * 1.0 : low  - atr * 2.0
float sellSL = inBearOB and not na(obBearTop) ? obBearTop + atr * 1.0 : high + atr * 2.0

float buyRisk  = close - buySL
float sellRisk = sellSL - close
float buyTP    = close + buyRisk  * rrRatio
float sellTP   = close - sellRisk * rrRatio

// ═══════════════════════════════════════════════════════════
//  PLOTS
// ═══════════════════════════════════════════════════════════
plotshape(bullishSignal, title="BUY",  location=location.belowbar,
  color=color.new(color.green,0), style=shape.triangleup,   size=size.normal, text="BUY")
plotshape(bearishSignal, title="SELL", location=location.abovebar,
  color=color.new(color.red,0),   style=shape.triangledown, size=size.normal, text="SELL")

if showScore and bullishSignal
    label.new(bar_index, low - atr*2.5,
      "✅ BUY  ⭐" + str.tostring(buyScore) + "/8\nSL " + str.tostring(math.round(buySL,2)) + "  TP " + str.tostring(math.round(buyTP,2)),
      color=color.new(color.green,10), textcolor=color.white, style=label.style_label_up, size=size.small)

if showScore and bearishSignal
    label.new(bar_index, high + atr*2.5,
      "🔴 SELL  ⭐" + str.tostring(sellScore) + "/8\nSL " + str.tostring(math.round(sellSL,2)) + "  TP " + str.tostring(math.round(sellTP,2)),
      color=color.new(color.red,10), textcolor=color.white, style=label.style_label_down, size=size.small)

// SL/TP Lines
var line slLine  = na
var line tpLine  = na
var line entLine = na

if bullishSignal
    line.delete(slLine)
    line.delete(tpLine)
    line.delete(entLine)
    slLine  := line.new(bar_index, buySL,  bar_index+15, buySL,  color=color.red,   style=line.style_dashed, width=1)
    tpLine  := line.new(bar_index, buyTP,  bar_index+15, buyTP,  color=color.green, style=line.style_solid,  width=2)
    entLine := line.new(bar_index, close,  bar_index+15, close,  color=color.blue,  style=line.style_dotted, width=1)

if bearishSignal
    line.delete(slLine)
    line.delete(tpLine)
    line.delete(entLine)
    slLine  := line.new(bar_index, sellSL,  bar_index+15, sellSL,  color=color.red,   style=line.style_dashed, width=1)
    tpLine  := line.new(bar_index, sellTP,  bar_index+15, sellTP,  color=color.green, style=line.style_solid,  width=2)
    entLine := line.new(bar_index, close,   bar_index+15, close,   color=color.blue,  style=line.style_dotted, width=1)

// Background
_bg = dailyBull and h4Bull ? color.new(color.green,96) : dailyBear and h4Bear ? color.new(color.red,96) : na
bgcolor(_bg)

// ═══════════════════════════════════════════════════════════
//  DASHBOARD
// ═══════════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 18,
  bgcolor=color.white, border_color=color.new(color.gray,60),
  border_width=1, frame_color=color.new(color.gray,40), frame_width=1)

if barstate.islast
    table.cell(dash, 0, 0, "📊 SMC v2.6",     text_color=color.white,  bgcolor=color.new(color.navy,10), text_size=size.small)
    table.cell(dash, 1, 0, "STATUS",           text_color=color.white,  bgcolor=color.new(color.navy,10), text_size=size.small)

    // Daily
    dLabel = dailyBull ? "🟢 BULL" : dailyBear ? "🔴 BEAR" : "🟡 NEUT"
    dColor = dailyBull ? color.lime : dailyBear ? color.red : color.yellow
    table.cell(dash, 0, 1, "Daily Bias",       text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 1, dLabel,             text_color=dColor,       text_size=size.tiny)

    // 4H
    h4Label = h4Bull ? "🟢 BULL" : h4Bear ? "🔴 BEAR" : "🟡 NEUT"
    h4Color = h4Bull ? color.lime : h4Bear ? color.red : color.yellow
    table.cell(dash, 0, 2, "4H Trend",         text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 2, h4Label,            text_color=h4Color,      text_size=size.tiny)

    // 1H
    h1Label = h1Bull ? "🟢 BULL" : h1Bear ? "🔴 BEAR" : "⚪ NEUT"
    h1Color = h1Bull ? color.lime : h1Bear ? color.red : color.gray
    table.cell(dash, 0, 3, "1H Momentum",      text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 3, h1Label,            text_color=h1Color,      text_size=size.tiny)

    // Trend alignment
    buyAlignLabel  = hardVetoBuy  ? "🚫 TRIPLE VETO" : trendAlignBuy  ? "✅ 4H ALIGNED" : "⚠ 4H UNALIGNED"
    sellAlignLabel = hardVetoSell ? "🚫 TRIPLE VETO" : trendAlignSell ? "✅ 4H ALIGNED" : "⚠ 4H UNALIGNED"
    buyAlignColor  = hardVetoBuy  ? color.red : trendAlignBuy  ? color.new(color.green,20) : color.orange
    sellAlignColor = hardVetoSell ? color.red : trendAlignSell ? color.new(color.green,20) : color.orange
    table.cell(dash, 0, 4, "BUY Alignment",    text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 4, buyAlignLabel,      text_color=buyAlignColor, text_size=size.tiny)
    table.cell(dash, 0, 5, "SELL Alignment",   text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 5, sellAlignLabel,     text_color=sellAlignColor, text_size=size.tiny)

    // RSI
    rsiTag  = rsiHardBlockBuy ? " ⛔BUY" : rsiHardBlockSell ? " ⛔SELL" : " ✅OK"
    rsiCol  = rsiHardBlockBuy or rsiHardBlockSell ? color.red : color.white
    table.cell(dash, 0, 6, "RSI",              text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 6, str.tostring(math.round(rsi,1)) + rsiTag, text_color=rsiCol, text_size=size.tiny)

    // Volume
    table.cell(dash, 0, 7, "Vol Spike",        text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 7, volSpike ? "⚡ YES" : "— NO", text_color=volSpike ? color.yellow : color.gray, text_size=size.tiny)

    // Liq sweeps
    table.cell(dash, 0, 8, "Liq Sweep ↑",      text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 8, liqSweepUp   ? "✅ YES" : "— NO", text_color=liqSweepUp   ? color.lime : color.gray, text_size=size.tiny)
    table.cell(dash, 0, 9, "Liq Sweep ↓",      text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 9, liqSweepDown ? "✅ YES" : "— NO", text_color=liqSweepDown ? color.lime : color.gray, text_size=size.tiny)

    // Scores
    bScoreCol = buyScore  >= minConfluence and trendAlignBuy  ? color.lime : color.gray
    sScoreCol = sellScore >= minConfluence and trendAlignSell ? color.red  : color.gray
    table.cell(dash, 0, 10, "Buy Score",       text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 10, str.tostring(buyScore)  + "/8", text_color=bScoreCol, text_size=size.tiny)
    table.cell(dash, 0, 11, "Sell Score",      text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 11, str.tostring(sellScore) + "/8", text_color=sScoreCol, text_size=size.tiny)

    // ATR
    table.cell(dash, 0, 12, "ATR%",            text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 12, str.tostring(math.round(atr_pct,2)) + "%", text_color=color.black, text_size=size.tiny)

    // OB status
    table.cell(dash, 0, 13, "Stretch %EMA50",  text_color=color.black, text_size=size.tiny)
    stretchCol  = stretchBlockBuy ? color.orange : stretchBlockSell ? color.orange : color.lime
    stretchTxt  = str.tostring(math.round(pctFromEMA50,1)) + "%" + (stretchBlockBuy ? " ⛔OB" : stretchBlockSell ? " ⛔OS" : " ✅")
    table.cell(dash, 1, 13, stretchTxt,        text_color=stretchCol,   text_size=size.tiny)
    table.cell(dash, 0, 14, "In Bull OB",      text_color=color.black, text_size=size.tiny)
    table.cell(dash, 1, 14, inBullOB ? "✅ YES" : "— NO", text_color=inBullOB ? color.lime : color.gray, text_size=size.tiny)

    // Signal readiness
    readyBuy  = buyScore  >= minConfluence and trendAlignBuy  and not hardVetoBuy  and not rsiHardBlockBuy and buyCooldownOK  and buyPriceOK
    readySell = sellScore >= minConfluence and trendAlignSell and not hardVetoSell and not rsiHardBlockSell and sellCooldownOK and sellPriceOK
    readyLabel = readyBuy ? "✅ BUY READY" : readySell ? "🔴 SELL READY" : "⏳ WAITING"
    readyColor = readyBuy ? color.lime : readySell ? color.red : color.gray
    table.cell(dash, 0, 15, "Signal",           text_color=color.silver,  text_size=size.tiny)
    table.cell(dash, 1, 15, readyLabel,          text_color=readyColor,    text_size=size.tiny)
    // Cooldown row
    cdBarsLeft = math.max(0, cooldownBars - (bar_index - math.min(lastBuyBar, lastSellBar)))
    cdLabel = buyCooldownOK and sellCooldownOK ? "✅ READY" : "⏳ " + str.tostring(cdBarsLeft) + " bars left"
    cdColor = buyCooldownOK and sellCooldownOK ? color.lime : color.orange
    table.cell(dash, 0, 16, "Cooldown",          text_color=color.silver,  text_size=size.tiny)
    table.cell(dash, 1, 16, cdLabel,             text_color=cdColor,       text_size=size.tiny)
